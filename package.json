{
  "name": "group-hardhat",
  "version": "1.0.0",
  "description": "基于 Merkle Tree 的去中心化群聊系统智能合约",
  "main": "index.js",
  "scripts": {
    "test": "hardhat test",
    "test:factory": "hardhat test test/CommunityFactory.ts",
    "test:community": "hardhat test test/Community.ts",
    "test:room": "hardhat test test/Room.ts",
    "test:integration": "hardhat test test/Integration.ts",
    "test:keydist": "hardhat test test/KeyDistribution.ts",
    "test:solidity": "hardhat test solidity",
    "compile": "hardhat compile",
    "clean": "hardhat clean",
    "deploy:local": "hardhat ignition deploy ignition/modules/CommunityFactory.ts",
    "deploy:arbitrum": "hardhat ignition deploy --network arbitrum --reset --verify --strategy create2 ignition/modules/CommunityFactory.ts",
    "deploy:opbnb": "hardhat ignition deploy --network opbnb --reset --verify ignition/modules/CommunityFactory.ts",
    "deploy:gnosis": "hardhat ignition deploy --network gnosis --reset --verify ignition/modules/CommunityFactory.ts",
    "script:create-community": "hardhat run scripts/create-community.ts",
    "script:create-room": "hardhat run scripts/create-room.ts",
    "merkle:generate": "hardhat run scripts/generate-merkle-proofs.ts",
    "create-communities:arbitrum": "hardhat run scripts/create-communities.ts --network arbitrum",
    "create-communities:opbnb": "hardhat run scripts/create-communities.ts --network opbnb",
    "create-communities:gnosis": "hardhat run scripts/create-communities.ts --network gnosis",
    "merkle:generate-all:arbitrum": "powershell -File scripts/generate-all-proofs.ps1 -Chain arbitrum",
    "merkle:generate-all:opbnb": "powershell -File scripts/generate-all-proofs.ps1 -Chain opbnb",
    "merkle:generate-all:gnosis": "powershell -File scripts/generate-all-proofs.ps1 -Chain gnosis",
    "set-merkle-roots:arbitrum": "hardhat run scripts/set-merkle-roots.ts --network arbitrum",
    "set-merkle-roots:opbnb": "hardhat run scripts/set-merkle-roots.ts --network opbnb",
    "set-merkle-roots:gnosis": "hardhat run scripts/set-merkle-roots.ts --network gnosis"
  },
  "keywords": [
    "blockchain",
    "smart-contracts",
    "hardhat",
    "merkle-tree",
    "chat",
    "群聊"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-ignition": "^3.0.3",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.0",
    "@openzeppelin/contracts": "^5.4.0",
    "@types/node": "^22.18.13",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.0.10",
    "typescript": "~5.8.0",
    "viem": "^2.38.6"
  },
  "type": "module",
  "dependencies": {
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.3",
    "merkletreejs": "^0.6.0"
  }
}
