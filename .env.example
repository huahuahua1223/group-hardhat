# ============================================
# Hardhat 环境变量配置
# ============================================
# 复制此文件为 .env 并填入真实值
# 注意：.env 文件已加入 .gitignore，不会被提交到 Git
#
# 配置优先级：
# 1. Hardhat vars (npx hardhat vars set) - 加密存储，最安全
# 2. .env 文件 - 本地开发方便
# 3. 系统环境变量
# ============================================

# ============================================
# 测试网配置
# ============================================

# Ethereum Sepolia 测试网
SEPOLIA_RPC_URL=https://rpc.sepolia.org
# 或使用 Alchemy: https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
# 或使用 Infura: https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# ============================================
# 主网配置
# ============================================

# Arbitrum One 主网 (ChainId: 42161)
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
# 或使用 Alchemy: https://arb-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# 或使用 Infura: https://arbitrum-mainnet.infura.io/v3/YOUR_PROJECT_ID
FACTORY_ADDRESS_ARBITRUM=0x你的CommunityFactory合约地址
RED_PACKET_ADDRESS_ARBITRUM=0x你的RedPacket合约地址

# opBNB Mainnet (ChainId: 204)
OPBNB_RPC_URL=https://opbnb-mainnet-rpc.bnbchain.org
# 或使用: https://opbnb.publicnode.com
FACTORY_ADDRESS_OPBNB=0x0000000000000000000000000000000000000000
RED_PACKET_ADDRESS_OPBNB=0x0000000000000000000000000000000000000000

# Gnosis Chain (ChainId: 100)
GNOSIS_RPC_URL=https://rpc.gnosischain.com
# 或使用: https://gnosis.publicnode.com
FACTORY_ADDRESS_GNOSIS=0x0000000000000000000000000000000000000000
RED_PACKET_ADDRESS_GNOSIS=0x0000000000000000000000000000000000000000

# ============================================
# 部署者私钥（所有链共用）
# ============================================
DEPLOYER_PRIVATE_KEY=0x你的私钥（不要提交到Git）

# ============================================
# 区块浏览器 API Key（用于合约验证）
# ============================================
ETHERSCAN_API_KEY=你的Etherscan_API_Key

# ============================================
# 安全提示：
# - 不要将 .env 文件提交到 Git
# - 不要使用主钱包的私钥
# - 为测试和生产使用不同的钱包
# - 定期轮换私钥
# ============================================